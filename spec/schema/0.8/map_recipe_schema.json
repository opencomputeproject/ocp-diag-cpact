{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Diagnostic Error Map Schema",
  "type": "object",
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "schema_revision": {
      "type": "string"
    },
    "DRCs": {
      "type": "object",
      "patternProperties": {
        "^.*$": {
          "type": "object",
          "required": [
            "message",
            "component",
            "severity",
            "actions",
            "confidence"
          ],
          "properties": {
            "message": {
              "type": "string"
            },
            "component": {
              "type": "string"
            },
            "severity": {
              "type": "string",
              "enum": ["NonFatal", "Critical", "Fatal"]
            },
            "search_strings": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "actions": {
                "type": "object",
                "patternProperties": {
                  "^[0-9]+$": {
                    "type": "string"
                  }
                },
                "additionalProperties": false
            },
            "confidence": {
              "type": "integer"
            }
          },
          "additionalProperties": true
        }
      }
    }
  },
  "required": ["schema_version", "schema_revision", "DRCs"],
  "additionalProperties": false
}